{
  "name": "proyecto-narannjja",
  "private": true,
  "version": "1.0.1",
  "description": "Suite de accesibilidad Proyecto Narannjja",
  "author": "Álvaro González Sánchez",
  "license": "GPL-3.0-or-later",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "npm run build && electron .",
    "electron:build": "npm run build && npx --no-install electron-builder --win --x64"
  },
  "build": {
    "appId": "com.proyectonaranja.app",
    "productName": "Proyecto Naranja",
    "copyright": "Copyright © 2026 Álvaro González Sánchez",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icons/win/icon.ico",
      "uninstallerIcon": "build/icons/win/icon.ico",
      "installerHeaderIcon": "build/icons/win/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Proyecto Narannjja",
      "installerLanguages": [
        "es_ES"
      ],
      "language": "3082"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "devr3x",
        "repo": "proyecto-narannjja"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-singlefile": "^2.3.3"
  }
}